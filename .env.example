# Supabase public client values. Leave blank to use local seed fallback data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional canonical production URL for metadata, sitemap, robots, and JSON-LD.
NEXT_PUBLIC_SITE_URL=

# Optional local analytics debug logging. Leave unset or false in production.
NEXT_PUBLIC_ANALYTICS_DEBUG=false

# Server-only key for private maintenance scripts if needed. Never expose with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only secret required for the protected RSS ingestion cron endpoint.
CRON_SECRET=
